<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hide Custom Module Menu -->
    <record id="pesantren_keuangan.keuangan_menu_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide Accounting Menu -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide POS Menu -->
    <record id="point_of_sale.menu_point_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide Purchase Menu -->
    <record id="purchase.menu_purchase_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide Inventory Menu -->
    <record id="stock.menu_stock_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide Cuti Menu -->
    <record id="hr_holidays.menu_hr_holidays_root" model="ir.ui.menu">
        <field name="active" eval="True"/>
    </record>

    <!-- Hide Job Queue Menu -->
    <record id="queue_job.menu_queue_job_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Hide PSB in karyawan not superuser -->
    <record id="pesantren_pendaftaran.pendaftaran_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Calendar Menu -->
    <record id="calendar.mail_menu_calendar" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Contact Menu -->
    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Dashboard Menu -->
    <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Time Off Menu -->
    <record id="hr_holidays.menu_hr_holidays_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide Link Tracer Menu -->
    <record id="utm.menu_link_tracker_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

    <!-- Hide App Menu -->
    <record id="base.menu_management" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>
</odoo>
