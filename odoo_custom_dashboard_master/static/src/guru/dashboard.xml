<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.OwlGuruDashboard" owl="1">
        <style>
            @media (max-width: 768px) {
                .controls-wrapper {
                flex-direction: column;
                width: 100%;
                }
                .dateButton {
                width: 100%;
                }
                .timerDropdown {
                display: flex;
                width: 100%;
                justify-content: space-between;
                margin-top: 0.5rem;
                }
                .dropdownButton {
                width: 100%;
                }
                .timer-button {
                width: 30%;
                }
                .header-text {
                font-size: 1.2rem;
                }
                /* Padding untuk mobile */
                .dashboard-container {
                    padding-left: 1rem !important;
                    padding-right: 1rem !important;
                }
            }

            .timerDropdown {
                display: flex;
                margin: 1rem;
            }

            /* Padding untuk container utama */
            .dashboard-container {
                padding-left: 2rem;
                padding-right: 2rem;
            }
            .batas-kiri {
                padding-left: 0 !important;
            }
            .batas-kanan {
                padding-right: 0 !important;
            }
        </style>
        <div class="container-fluid vh-100 bg-muted mb-5 pb-5 dashboard-container">
            <!-- Header Full Width -->
            <div class="my-1">
                <div class="col-12">
                    <div class="pt-2 pb-2">
                        <div class="d-flex flex-wrap align-items-center justify-content-between">
                            <div class="d-flex">
                                <h2 class="text-primary fw-bold header-text">Dashboard Guru</h2>
                            </div>
                            <div class="controls-wrapper d-flex align-items-center mt-1 position-relative">
                                <!-- Custom Date Range Button -->
                                <div class="button-popup-wrapper">
                                    <button class="btn btn-outline-secondary dateButton" t-on-click="toggleDatePicker">
                                        <i class="fas fa-calendar"></i>
                                        <t t-if="state.selectedDateRange">
                                            <span t-esc="formatDateRange(state.selectedDateRange.start, state.selectedDateRange.end)" class="ms-2" />
                                        </t>
                                    </button>

                                    <div t-if="state.showDatePicker" class="popup-container bg-white p-3 rounded shadow-lg mt-2" style="z-index:1050;">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="date-range d-flex flex-column">
                                                <label class="date-label text-center">Dari</label>
                                                <input type="date" class="form-control date-input" t-model="state.tempDateRange.start" t-on-change="applyDateRange" />
                                            </div>
                                            <div class="date-range d-flex flex-column">
                                                <label class="date-label text-center">Sampai</label>
                                                <input type="date" class="form-control date-input" t-model="state.tempDateRange.end" t-on-change="applyDateRange" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="timerDropdown">
                                    <!-- Dropdown Periode -->
                                    <div class="dropdown me-3 dropdownButton">
                                        <button class="btn btn-outline-secondary dropdown-toggle dropdownButton" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <span t-esc="getPeriodLabel(state.selectedPeriod)" />
                                        </button>
                                        <ul class="dropdown-menu dropdownButton">
                                            <li>
                                                <a class="dropdown-item d-flex justify-content-between align-items-center" href="#" t-on-click.prevent="() => this.setPeriod('custom')">
                          Default
                                                    <i class="fas fa-check" t-att-class="{'invisible': !isPeriodSelected('custom')}"></i>
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('today')">Hari Ini</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('yesterday')">Kemarin</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('thisWeek')">Minggu Ini</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('lastWeek')">Minggu Lalu</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('thisMonth')">Bulan Ini</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('lastMonth')">Bulan Lalu</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('thisYear')">Tahun Ini</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" href="#" t-on-click.prevent="() => this.setPeriod('lastYear')">Tahun Lalu</a>
                                            </li>
                                        </ul>
                                    </div>

                                    <!-- Timer Button -->
                                    <button id="timerButton" class="btn btn-outline-secondary timer-button">
                                        <i id="timerIcon" class="fas fa-clock"></i>
                                        <span id="timerCountdown"></span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="mx-1 my-0">
                <GuruKpiCard startDate="dateRangeProps.startDate" endDate="dateRangeProps.endDate"/>
            </div>

            <div class="row mx-0 my-2">
                <div class="col-lg-6 col-md-12 col-sm-12 m-0 pr-2 py-2 batas-kiri">
                    <div class="shadow-sm p-4 bg-white" style="width: 100%; height: 400px;">
                        <div class="d-flex align-items-center justify-content-between">
                            <h4 class="text-dark fw-bold">Absensi Siswa per Kehadiran</h4>
                        </div>
                        <GuruChartRenderer type="'pie'" title="'pie1'" startDate="dateRangeProps.startDate" endDate="dateRangeProps.endDate"/>
                    </div>
                </div>
                <div class="col-lg-6 col-md-12 col-sm-12 m-0 pl-2 py-2 batas-kanan">
                    <div class="shadow-sm p-4 bg-white" style="width: 100%; height: 400px;">
                        <div class="d-flex align-items-center justify-content-between">
                            <h4 class="text-dark fw-bold">Absen Halaqoh per Kehadiran</h4>
                        </div>
                        <GuruChartRenderer type="'pie'" title="'pie2'" startDate="dateRangeProps.startDate" endDate="dateRangeProps.endDate"/>
                    </div>
                </div>
            </div>
            <div class="row mx-0 my-2 pb-4">
                <div class="col-lg-6 col-md-12 col-sm-12 m-0 pr-2 batas-kiri">
                    <GuruList startDate="dateRangeProps.startDate" endDate="dateRangeProps.endDate"/>
                </div>
                <div class="col-lg-6 col-md-12 col-sm-12 m-0 pl-2 batas-kanan">
                    <EkskulList startDate="dateRangeProps.startDate" endDate="dateRangeProps.endDate"/>
                </div>
            </div>
        </div>
    </t>
</templates>