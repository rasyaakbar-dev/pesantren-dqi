<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.KeamananCardList2" owl="1">
        <div class="row w-100 h-100 m-0" style="font-size: 0.8rem; line-height: 1.5;">
            <div class="col-lg-12 p-0">
                <div class="card shadow-sm border-0 rounded-0">
                    <div class="card-header d-flex justify-content-center align-items-center bg-primary text-white">
                        <h3 class="card-title text-white mb-0">Terakhir Masuk</h3>
                    </div>
                    <div class="card-body pt-1 p-0" style="min-height: 400px;">
                        <t t-if="state.keluarIjin.length > 0">
                            <div style="overflow-x: auto; max-height: 380px; overflow-y: auto;">
                                <table class="table table-hover table-striped mb-0">
                                    <thead style="position: sticky; top: 0; background-color: white; z-index: 1;">
                                        <tr>
                                            <th>#</th>
                                            <th>Nomor</th>
                                            <th>Nama Santri</th>
                                            <th>Tgl Masuk</th>
                                            <th>Keperluan</th>
                                            <th>Lama Ijin</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="overflow-x-scroll">
                                        <t t-foreach="state.keluarIjin" t-as="ijin" t-key="ijin.id">
                                            <tr style="cursor: pointer;" t-att-id="'product-' + ijin.id" t-on-click="() => this.onProductClick(ijin.id)">
                                                <td>
                                                    <t t-esc="ijin.number"/>
                                                </td>
                                                <td>
                                                    <t t-esc="ijin.name"/>
                                                </td>
                                                <td>
                                                    <t t-esc="ijin.siswa"/>
                                                </td>
                                                <td>
                                                    <t t-esc="ijin.tgl_ijin"/>
                                                </td>
                                                <td>
                                                    <t t-esc="ijin.keperluan"/>
                                                </td> 
                                                <td>
                                                    <t t-esc="ijin.lamaijin"/>
                                                </td>
                                                <td>
                                                    <span t-if="ijin.state == 'Return'" class="badge rounded-pill bg-success text-light">Masuk</span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="text-center p-3 text-muted">
                                <i class="fa fa-info-circle me-1"></i> Data tidak ditemukan
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>