<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl.SekolahChartRenderer" owl="1">
        <!-- Conditional rendering for the chart or the "Data tidak ditemukan" message -->
        <t t-if="hasData" class="p-5">
            <!-- The canvas element for the chart -->
            <canvas t-ref="chart" style="display: block; margin: 0 auto;" />
        </t>
        <t t-else="">
            <div class="d-flex flex-column align-items-center justify-content-center h-100 p-5">
                <i class="fa fa-chart-pie fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-0">Data tidak ditemukan.</p>
            </div>
        </t>
    </t>
</templates>