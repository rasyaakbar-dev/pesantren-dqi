        <!-- This data file creates the initial role records based on existing jns_pegawai values -->
        <record id="jenis_pegawai_musyrif" model="cdn.jenis_pegawai">
            <field name="name">Musyrif</field>
            <field name="code">musyrif</field>
            <field name="description">Musyrif - Pengasuh asrama</field>
            <field name="sequence">10</field>
