<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- cdn.jadwal_pelajaran list view -->
        <record id="cdn_jadwal_pelajaran_view_tree" model="ir.ui.view">
            <field name="name">cdn.jadwal_pelajaran.view.list</field>
            <field name="model">cdn.jadwal_pelajaran</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="tahunajaran_id" />
                    <field name="kelas_id" />
                    <field name="jenjang" />
                </list>
            </field>
        </record>

        <!-- cdn.jadwal_pelajaran form view -->
        <record id="cdn_jadwal_pelajaran_view_form" model="ir.ui.view">
            <field name="name">cdn.jadwal_pelajaran.view.form</field>
            <field name="model">cdn.jadwal_pelajaran</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="name" nolabel="1" />
                        <group>
                            <group>
                                <field name="tahunajaran_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                <field name="kelas_id" on_change="1"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                            </group>
                            <group>
                                <field name="semester" />
                                <field name="walikelas_id" />
                            </group>
                        </group>
                        <field name="jadwal_ids" nolabel="1" mode="list,form">
                            <list>
                                <field name="name" />
                                <field name="jampelajaran_id" options="{'no_create_edit':True}" />
                                <field name="start_time" widget="float_time" />
                                <field name="end_time" widget="float_time" />
                                <field name="matapelajaran_id" nolabel="1"
                                    options="{'no_create_edit':True}" />
                                <field name="guru_id" widget="many2many_tags"
                                    options="{'no_create_edit':True}" />
                            </list>
                            <form>
                                <group>
                                    <group>
                                        <field name="name" />
                                        <field name="kelas_id" readonly="1" />
                                        <field name="jenjang" />
                                        <field name="jampelajaran_id" />
                                    </group>
                                    <group>
                                        <field name="start_time" widget="float_time" readonly="1" />
                                        <field name="end_time" widget="float_time" readonly="1" />
                                        <field name="matapelajaran_id" />
                                        <field name="guru_id" widget="many2many_tags" />
                                    </group>
                                </group>
                            </form>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- cdn.jadwal_pelajaran action window -->
        <record id="cdn_jadwal_pelajaran_action" model="ir.actions.act_window">
            <field name="name">Jadwal Pelajaran</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.jadwal_pelajaran</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="jadwal_pelajaran_menu_act" name="Jadwal Pelajaran"
            parent="pengaturan_akademik_menu_categ" action="cdn_jadwal_pelajaran_action"
            sequence="10" />
    </data>
</odoo>