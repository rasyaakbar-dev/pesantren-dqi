<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Jenis Pegawai List View -->
    <record id="view_jenis_pegawai_tree" model="ir.ui.view">
        <field name="name">cdn.jenis_pegawai.list</field>
        <field name="model">cdn.jenis_pegawai</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Jenis Pegawai" editable="bottom">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="code" />
                <field name="active" widget="boolean_toggle" />
            </list>
        </field>
    </record>

    <!-- Jenis Pegawai Form View -->
    <record id="view_jenis_pegawai_form" model="ir.ui.view">
        <field name="name">cdn.jenis_pegawai.form</field>
        <field name="model">cdn.jenis_pegawai</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Jenis Pegawai">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="code" />
                            <field name="sequence" />
                            <field name="active" />
                            <field name="color" widget="color_picker" />
                        </group>
                        <group>
                            <field name="description" placeholder="Deskripsi role..." />
                        </group>
                    </group>
                    <notebook>
                        <page string="Security Groups">
                            <field name="security_group_ids" widget="many2many_tags"
                                options="{'no_create': True, 'no_create_edit': True}" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Jenis Pegawai Search View -->
    <record id="view_jenis_pegawai_search" model="ir.ui.view">
        <field name="name">cdn.jenis_pegawai.search</field>
        <field name="model">cdn.jenis_pegawai</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Jenis Pegawai">
                <field name="name" />
                <field name="code" />
                <filter string="Active" name="active" domain="[('active', '=', True)]" />
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]" />
            </search>
        </field>
    </record>

    <!-- Jenis Pegawai Action -->
    <record id="action_jenis_pegawai" model="ir.actions.act_window">
        <field name="name">Jenis Pegawai</field>
        <field name="res_model">cdn.jenis_pegawai</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_jenis_pegawai_tree" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Buat Role Baru
            </p>
            <p>
                Role menentukan jenis pegawai yang dapat ditugaskan kepada karyawan.
                Setiap role dapat memiliki security groups yang akan otomatis diberikan kepada
                karyawan dengan role tersebut.
            </p>
        </field>
    </record>
</odoo>