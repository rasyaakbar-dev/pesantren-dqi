<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="view_cdn_orangtua_tree" model="ir.ui.view">
            <field name="name">cdn_orangtua_tree</field>
            <field name="model">cdn.orangtua</field>
            <field name="type">list</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <list string="Orangtua">
                    <field name="name" />
                    <field name="nik" />
                    <field name="street" string="Alamat" />
                    <field name="phone" string="No. Telepon" />
                    <field name="email" />
                    <field name="hubungan" />
                </list>
            </field>
        </record>

        <!-- form view -->
        <record id="view_cdn_orangtua_form" model="ir.ui.view">
            <field name="name">cdn_orangtua_form</field>
            <field name="model">cdn.orangtua</field>
            <field name="type">form</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <form string="Orangtua">
                    <header>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box"> </div>

                        <group string="Data Orang Tua">
                            <group>
                                <field name="name" />
                                <field name="email" string="Email" />
                                <field name="password" string="Password" widget="password_toggle" />
                                <field name="phone" string="No. Telepon" />
                                <field name="nik" />
                                <field name="jns_partner" readonly="1" string="Kategori Pengguna" />
                            </group>

                            <group>
                                <field name="street" string="Alamat" />
                                <field name="city" string="Kota" />
                                <field name="street2" string="RT/RW" />
                                <field name="hubungan" />
                                <field name="label" widget="many2many_tags"
                                    options="{'color_field': 'color'}" />
                                <field name="isLimit" widget="boolean_toogle" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Santri">
                                <field name="siswa_ids" nolabel="1" widget="one2many_tree">
                                    <list create="false" edit="false" delete="false">
                                        <field name="nis" />
                                        <field name="name" />
                                        <field name="jns_kelamin" />
                                        <field name="tmp_lahir" />
                                        <field name="tgl_lahir" />
                                        <field name="tahunajaran_id" />
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="view_cdn_orangtua_search" model="ir.ui.view">
            <field name="name">cdn_orangtua</field>
            <field name="model">cdn.orangtua</field>
            <field name="arch" type="xml">
                <search string="Orangtua">

                    <field name="name" string="Data"
                        filter_domain="[
                            '|', ('name', 'ilike', self), 
                            '|', ('nik', 'ilike', self),
                            '|', ('city', 'ilike', self),
                            '|', ('street', 'ilike', self),
                            '|', ('mobile', 'ilike', self),
                            '|', ('street2', 'ilike', self),
                            '|', ('email', 'ilike', self),
                            '|', ('phone', 'ilike', self),
                            '|', ('user_id', 'ilike', self),
                            '|', ('partner_id', 'ilike', self),
                            ('hubungan', 'ilike', self)
                        ]" />
                </search>
            </field>
        </record>

        <!-- action window -->
        <record id="action_cdn_orangtua" model="ir.actions.act_window">
            <field name="name">Orangtua</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.orangtua</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname":1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to add a new Orangtua
                </p>
                <p>
                    Click the Create button to add a new Orangtua
                </p>
            </field>
        </record>

        <menuitem id="menu_cdn_orangtua" name="Orang Tua" parent="siswa_menu_categ"
            action="action_cdn_orangtua" sequence="30" />
    </data>
</odoo>