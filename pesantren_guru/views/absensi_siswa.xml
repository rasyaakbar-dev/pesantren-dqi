<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- Inherit Absen form view siswa-->
        <record id="view_inherited_tahfidz_quran" model="ir.ui.view">
            <field name="name">inherited.tahfidz.quran.form</field>
            <field name="model">cdn.siswa</field>
            <field name="inherit_id" ref="pesantren_base.view_cdn_siswa_form" />
            <field name="arch" type="xml">
                <!-- Inherit the specific page by its name attribute -->
                <xpath expr="//notebook" position="inside">
                    <page string="KBM" name="kbm_samtri">
                        <!-- You can add other modifications or elements here -->
                        <field name="kbm_id">
                            <list default_order="id desc" create="false">
                                <field name="name" />
                                <field name="tanggal" />
                                <field name="kelas_id" />
                                <field name="mapel_id" />
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="cdn_absensi_siswa_view_tree" model="ir.ui.view">
            <field name="name">cdn.absensi_siswa.view.list</field>
            <field name="model">cdn.absensi_siswa</field>
            <field name="arch" type="xml">
                <list>
                    <field name="row_number" string="#" />
                    <field name="name" optional="show" />
                    <field name="tanggal" optional="show" />
                    <field name="jampelajaran_id" optional="show" widget="many2many_tags" />
                    <field name="kelas_id" optional="show" />
                    <field name="mapel_id" optional="show" />
                    <field name="guru_id" optional="show" />
                    <field name="tema" optional="hide" />
                    <field name="materi" optional="hide" />
                    <field name="rpp_id" optional="hide" />
                    <field name="company_id" optional="hide" />
                    <field name="state" optional="show" />
                </list>
            </field>
        </record>

        <record id="cdn_absensi_siswa_view_form" model="ir.ui.view">
            <field name="name">cdn.absensi_siswa.view.form</field>
            <field name="model">cdn.absensi_siswa</field>
            <field name="arch" type="xml">
                <form string="">
                    <header>
                        <button name="action_draft" string="Set to Draft" type="object"
                            invisible="state != 'done'" class="btn-default" />
                        <button name="action_done" string="Confirm" type="object"
                            invisible="state != 'draft'" class="btn-primary" />
                        <field name="state" widget="statusbar" />
                    </header>
                    <sheet>
                        <group string="Kelas">
                            <group>
                                <field name="kelas_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                            </group>
                            <group>
                                <field name="tanggal" />
                            </group>
                        </group>

                        <group string="Aktivitas Pelajaran">
                            <group>
                                <field name="hari" />
                                <field name="jampelajaran_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
                                    widget="many2many_tags" />
                                <field name="company_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
                                    readonly="1" />
                            </group>
                            <group>
                                <field name="mapel_id"
                                    domain="[('jenjang', '=', jenjang), '|', ('tingkat_id', '=', False), ('tingkat_id', '=', tingkat_id)]"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                <field name="guru_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Absensi Siswa">
                                <field name="absensi_ids" nolable="1">
                                    <list editable="bottom" create="false" delete="false">
                                        <field name="row_number" string="#" />
                                        <field name="siswa_id"
                                            options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                        <field name="panggilan" string="Panggilan" />
                                        <field name="nis" />
                                        <field
                                            name="kehadiran"
                                            decoration-bf="True"
                                            decoration-danger="kehadiran=='Alpa'"
                                            decoration-warning="kehadiran=='Izin' or kehadiran=='keluar'"
                                            decoration-success="kehadiran=='Hadir'"
                                            decoration-muted="kehadiran=='Sakit'"
                                        />
                                        <field name="keterangan" />
                                        <field name="keterangan_izin"
                                            filename="keterangan_izin_filename" />
                                        <button name="action_view_permission"
                                            string="Detail"
                                            type="object"
                                            icon="fa-eye"
                                            invisible="kehadiran != 'keluar'"
                                            class="btn-primary" />
                                    </list>
                                </field>
                            </page>
                            <page string="Jurnal">
                                <group>
                                    <group>
                                        <field name="tingkat_id" invisible="1" />
                                        <field name="tema" />
                                        <field name="materi" />
                                    </group>
                                    <group>
                                        <field name="rpp_id"
                                            domain="[('tingkat_id', '=', tingkat_id),('matpel_id','=',mapel_id)]"
                                            options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                        <field name="pertemuan_ke" />
                                    </group>
                                </group>
                                <field name="dokumen" widget="pdf_viewer" nolable="1" />
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- cdn.absensi_siswa action window -->
        <record id="cdn_absensi_siswa_action" model="ir.actions.act_window">
            <field name="name">Absensi Siswa</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.absensi_siswa</field>
            <field name="view_mode">list,form</field>
            <field name="domain">
                [
                ('state', 'in', ['draft', 'done'])
                ]
            </field>
        </record>
        <!-- 🔹 Tambahkan action untuk membuka wizard filter manual -->
        <record id="action_open_absensi_filter_wizard" model="ir.actions.act_window">
            <field name="name">Filter Tanggal Manual</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.absensi.filter.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>
        <menuitem id="cdn_absensi_siswa_menu_act" name="Absensi Siswa"
            parent="absensi_pengajar" action="cdn_absensi_siswa_action" sequence="10"
            groups="pesantren_guru.group_guru_staff" />
    </data>
</odoo>