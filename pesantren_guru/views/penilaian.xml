<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<!-- cdn.penilaian list view -->
		<record id="cdn_penilaian_view_tree" model="ir.ui.view">
			<field name="name">cdn.penilaian.view.list</field>
			<field name="model">cdn.penilaian</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
					<field name="kelas_id" />
					<field name="mapel_id" />
					<field name="guru_id" />
					<field name="semester" />
					<field name="tipe" />
					<field name="company_id" optional="hide" />
					<field name="state" />
				</list>
			</field>
		</record>

		<!-- cdn.penilaian form view -->
		<record id="cdn_penilaian_view_form" model="ir.ui.view">
			<field name="name">cdn.penilaian.view.form</field>
			<field name="model">cdn.penilaian</field>
			<field name="arch" type="xml">
				<form string="">
					<header>
						<button name="action_draft" string="Draft" type="object" class="btn-default"
							invisible="state != 'done'" groups="pesantren_guru.group_guru_staff" />
						<button name="action_done" string="Done" type="object" class="btn-primary"
							invisible="state != 'draft'" groups="pesantren_guru.group_guru_staff" />
						<field name="state" widget="statusbar" />
					</header>
					<sheet>

						<group string="Penilaian">
							<field name="id" invisible="1" />
							<group>
								<field name="guru_id"
									options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
								<field name="kelas_id"
									options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
								<field name="mapel_id"
									domain="[('jenjang', '=', jenjang), '|', ('tingkat_id', '=', False), ('tingkat_id', '=', tingkat_id), ('guru_ids','in',[guru_id])]"
									options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
							</group>
							<group>
								<field name="semester" />
								<field name="tipe" />
								<field name="company_id"
									options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
									readonly="1" />
							</group>
						</group>

						<field name="penilaian_ids" nolable="true"
							context="{
                            'default_id_penilaian': id,
                            'default_id_kelas':kelas_id}">
							<list editable="bottom">
								<field name="name" string="Tipe" />
								<field name="siswa_id"
									domain="[('ruang_kelas_id', '=', id_kelas)]"
									options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
								<field name="panggilan" string="Panggilan" />
								<field name="nilai" widget="integer" />
								<field name="predikat" />
							</list>
						</field>
					</sheet>
				</form>
			</field>
		</record>

		<record id="view_penilaian_search" model="ir.ui.view">
			<field name="name">cdn.penilaian.search</field>
			<field name="model">cdn.penilaian</field>
			<field name="arch" type="xml">
				<search>
					<field name="guru_id" />
				</search>
			</field>
		</record>

		<!-- cdn.penilaian action window -->
		<record id="cdn_penilaian_action" model="ir.actions.act_window">
			<field name="name">Penilaian Siswa</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">cdn.penilaian</field>
			<field name="view_mode">list,form</field>
			<field name="search_view_id" ref="view_penilaian_search" />
			<field name="domain" eval="[]" />
		</record>

		<!-- This Menu Item must have a parent and an action -->
		<menuitem id="penilaian_menu_act" name="Penilaian Siswa"
			parent="aktivitas_penilaian_menu_categ" action="cdn_penilaian_action" sequence="10" />
	</data>
</odoo>