<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_absensi_filter_wizard_form" model="ir.ui.view">
        <field name="name">cdn.absensi.filter.wizard.form</field>
        <field name="model">cdn.absensi.filter.wizard</field>
        <field name="arch" type="xml">
            <form string="Filter Tanggal Absensi">
                <group>
                    <field name="date_start" />
                    <field name="date_end" />
                </group>
                <footer>
                    <button name="action_filter" string="Tampilkan Data" type="object"
                        class="btn-primary" />
                    <button string="Batal" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>
    <record id="action_absensi_filter_wizard" model="ir.actions.act_window">
        <field name="name">Filter Tanggal Manual</field>
        <field name="res_model">cdn.absensi.filter.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>