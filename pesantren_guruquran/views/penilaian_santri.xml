<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- cdn.penilaian_santri list view -->
        <record id="cdn_penilaian_santri_view_tree" model="ir.ui.view">
            <field name="name">cdn.penilaian_santri.view.list</field>
            <field name="model">cdn.penilaian_santri</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" />
                    <field name="halaqoh_id" context="{'from_guru_quran': True}" />
                    <field name="kategori_penilaian" />
                    <field name="guru_id" />
                    <field name="tipe" />
                    <field name="company_id" optional="hide" />
                    <field name="state" />
                </list>
            </field>
        </record>

        <!-- cdn.penilaian_santri form view -->
        <record id="cdn_penilaian_santri_view_form" model="ir.ui.view">
            <field name="name">cdn.penilaian_santri.view.form</field>
            <field name="model">cdn.penilaian_santri</field>
            <field name="arch" type="xml">
                <form string="">
                    <header>
                        <button name="action_draft" string="Draft" type="object" class="btn-default"
                            invisible="state != 'done'"
                            groups="pesantren_guruquran.group_guru_quran_staff" />
                        <button name="action_done" string="Done" type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="pesantren_guruquran.group_guru_quran_staff" />
                        <field name="state" widget="statusbar" />
                    </header>
                    <sheet>

                        <group string="Penilaian Santri">
                            <field name="id" invisible="1" />
                            <group>
                                <field name="guru_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                <field name="halaqoh_id"
                                    domain="[('penanggung_jawab_id','in',[guru_id])]"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
                                    context="{'from_guru_quran': True}" />
                                <field name="company_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
                                    readonly="1" />
                            </group>
                            <group>
                                <field name="kategori_penilaian"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" />
                                <field name="tipe" />
                            </group>
                        </group>

                        <field name="penilaian_santri_ids" nolable="true"
                            context="{
                            'default_id_penilaian_santri': id,
                            'default_id_halaqoh':halaqoh_id}">
                            <list editable="bottom">
                                <field name="name" string="Tipe" />
                                <!-- <field name="id_penilaian" invisible="1"/> -->
                                <!-- <field name="id_kelas" invisible="1"/> -->
                                <!-- <field name="state" invisible="1"/> -->
                                <field name="santri_id"
                                    domain="[('halaqoh_id', '=', id_halaqoh)]"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}"
                                    context="{'from_guru_quran': True}" />
                                <field name="panggilan" string="Panggilan" />
                                <field name="nilai" widget="integer" />
                                <field name="predikat" />
                                <field name="juz" />
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_penilaian_santri_search" model="ir.ui.view">
            <field name="name">cdn.penilaian_santri.search</field>
            <field name="model">cdn.penilaian_santri</field>
            <field name="arch" type="xml">
                <search>
                    <field name="guru_id" />
                </search>
            </field>
        </record>

        <!-- cdn.penilaian action window -->
        <record id="cdn_penilaian_santri_action" model="ir.actions.act_window">
            <field name="name">Data Penilaian Santri</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.penilaian_santri</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_penilaian_santri_search" />
            <field name="context">{'from_guru_quran': True}</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="penilaian_santri_menu_act" name="Penilaian Santri"
            parent="pesantren_guru.tahfidz_tahsin" action="cdn_penilaian_santri_action" sequence="5"
            groups="pesantren_guruquran.group_guru_quran_staff" />
    </data>
</odoo>