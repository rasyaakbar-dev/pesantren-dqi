<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- cdn.absen_halaqoh list view -->
        <record id="cdn_absen_halaqoh_view_tree" model="ir.ui.view">
            <field name="name">cdn.absen_halaqoh.view.list</field>
            <field name="model">cdn.absen_halaqoh</field>
            <field name="arch" type="xml">
                <list default_order="id desc" >
                    <field name="row_number" string="#" />
                    <field name="name" />
                    <field name="sesi_id" />
                    <field name="halaqoh_id" string="Halaqah" context="{'from_guru_quran': True}" />
                    <field name="ustadz_id" />
                    <field name="company_id" optional="hide"/>
                    <field name="state" />
                </list>
            </field>
        </record>

        <!-- cdn.absen_halaqoh form view -->
        <!-- Form View -->
        <record id="cdn_absen_halaqoh_view_form" model="ir.ui.view">
            <field name="name">cdn.absen_halaqoh.view.form</field>
            <field name="model">cdn.absen_halaqoh</field>
            <field name="arch" type="xml">
                <form string="Absensi Halaqoh">
                    <header>
                        <!-- <field name="state" widget="statusbar" statusbar_visible="draft,proses,done"/> -->
                        <!-- <button string="Proses" name="action_proses" type="object" class="btn btn-primary"
                                invisible="state == 'proses' or state == 'done'"/>
                        <button string="Selesai" name="action_confirm" type="object" class="btn btn-primary"
                                invisible="state == 'draft' or state == 'done'"/> -->
                        <!-- <button string="Proses" type="object" name="action_proses" 
                                invisible="state != 'proses' or state != 'done'" class="oe_highlight"/>
                        <button string="Done" type="object" name="action_confirm" 
                                invisible="state != 'draft' or state != 'done'"/> -->
                    <!-- <field name="state" widget="statusbar"/>         -->
                        <button string="Proses" name="action_proses" type="object" class="oe_highlight" invisible="state != 'Draft'" context="{'from_guru_quran': True}"/>
                        <button string="Selesai" name="action_confirm" type="object" class="oe_highlight" invisible="state != 'Proses'"/>
                        <button string="Sinkronkan Penilaian" name="action_sync_penilaian" type="object" class="oe_highlight" invisible="state == 'Draft'" context="{'from_guru_quran': True}"/>
                        <field name="state" widget="statusbar" />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="fiscalyear_id" readonly="1"/>
                                <field name="sesi_id"/>
                                <field name="company_id"
                                    options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" readonly="1"/>
                            </group>
                            <group>
                                <field name="halaqoh_id" options="{'no_create_edit': True, 'no_create': True}"/>
                                <field name="ustadz_id" options="{'no_create_edit': True, 'no_create': True}"/>
                                <field name="keterangan"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Daftar Kehadiran">
                                <field colspan="4" name="absen_ids" nolabel="1" widget="one2many_list">
                                    <list string="" editable="top">
                                        <field name="row_number" string="#" />
                                        <field name="siswa_id" options="{'no_create_edit':True, 'no_create':True, 'no_open': True}" string="Santri"/>
                                        <field name="panggilan" string="Panggilan"/>
                                        <field name="nis" />
                                        <field 
                                            name="kehadiran" 
                                            decoration-bf="True"
                                            decoration-danger="kehadiran=='Alpa'" 
                                            decoration-warning="kehadiran=='Izin' or kehadiran=='keluar'" 
                                            decoration-success="kehadiran=='Hadir'" 
                                            decoration-muted="kehadiran=='Sakit'"
                                        />
                                        <field name="keterangan" />
                                        <field name="keterangan_izin" filename="keterangan_izin_filename" />
                                        <button name="action_view_permission"
                                            string="Detail"
                                            type="object"
                                            icon="fa-eye"
                                            invisible="kehadiran != 'keluar'"
                                            class="btn-primary"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- cdn.absen_halaqoh search view -->
        <record id="cdn_absen_absen_halaqoh_view_search" model="ir.ui.view">
            <field name="name">cdn.absen_halaqoh.view.search</field>
            <field name="model">cdn.absen_halaqoh</field>
            <field name="arch" type="xml">
                <search string="Search Description">
                    <!-- Add your fields here -->
                    <field name="ustadz_id" string="Data"
                        filter_domain="[
                            '|', ('halaqoh_id.name', 'ilike', self),
                            '|', ('ustadz_id.name', 'ilike', self),
                            '|', ('fiscalyear_id.name', 'ilike', self),
                            '|', ('absen_ids.name', 'ilike', self),
                            '|', ('absen_ids.siswa_id.name', 'ilike', self),
                            '|', ('absen_ids.siswa_id.nis', 'ilike', self),
                            '|', ('absen_ids.siswa_id.barcode_santri', 'ilike', self),
                            '|', ('penanggung_jawab_id.name', 'ilike', self),
                            '|', ('state', 'ilike', self),
                            ('name', 'ilike', self),
                        ]"
                    />

                    <filter string="Hari Ini" name="today" domain="[
                        ('name','=',(context_today().strftime('%Y-%m-%d'))),
                    ]" /> 

                    <filter string="Hari Ini &amp; Kemarin" name="today_yesterday"
                    domain="[
                        ('name', '&gt;=', (context_today() - relativedelta(days=1))),
                        ('name', '&lt;=', context_today())
                    ]"/>

                    <!-- GROUP BY Section -->
                    <group expand="1" string="Group By">
                        <filter string="Halaqoh" name="group_halaqoh"  context="{'group_by': 'halaqoh_id', 'orderby': 'halaqoh_id.name asc'}"/>
                        <filter string="Ustadz" name="group_ustadz" context="{'group_by': 'ustadz_id'}"/>
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- cdn.absen_halaqoh action window -->
        <record id="cdn_absen_halaqoh_action" model="ir.actions.act_window">
            <field name="name">Absensi Halaqoh</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.absen_halaqoh</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                'from_guru_quran': True,
                'orderby': 'halaqoh_id.name asc'
            }</field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="cdn_absen_halaqoh_menu_act" name="Absensi Halaqoh" 
            parent="kepesantrenan_halaqoh_menu_categ" action="cdn_absen_halaqoh_action" sequence="10"/>
        
    </data>
</odoo> 