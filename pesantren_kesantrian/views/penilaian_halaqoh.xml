    <record id="view_penilaian_quran_line_search" model="ir.ui.view">
        <field name="name">cdn.penilaian_quran_line.search</field>
        <field name="model">cdn.penilaian_quran_line</field>
        <field name="arch" type="xml">
            <search string="Cari Riwayat Hafalan">
                <field name="penilaian_id" string="Referensi" />
                <field name="surah_id" string="Surah" />
                <field name="halaqoh_id" string="Halaqoh" />
                <field name="ustadz_id" string="Ustadz" />
                <field name="tanggal_penilaian" string="Tanggal" />

                <separator />

                <!-- Filter berdasarkan tanggal -->
                <filter name="filter_today" string="Hari Ini"
                    domain="[('tanggal_penilaian','=',context_today().strftime('%Y-%m-%d'))]" />
                <filter name="filter_this_week" string="Minggu Ini"
                    domain="[('tanggal_penilaian','&gt;=',(context_today()-relativedelta(days=7)).strftime('%Y-%m-%d'))]" />
                <filter name="filter_this_month" string="Bulan Ini"
                    domain="[('tanggal_penilaian','&gt;=',(context_today()-relativedelta(months=1)).strftime('%Y-%m-%d'))]" />

                <separator />

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_tanggal" string="Tanggal"
                        context="{'group_by': 'tanggal_penilaian'}" />
                    <filter name="group_surah" string="Surah" context="{'group_by': 'surah_id'}" />
                    <filter name="group_halaqoh" string="Halaqoh"
                        context="{'group_by': 'halaqoh_id'}" />
                    <filter name="group_ustadz" string="Ustadz" context="{'group_by': 'ustadz_id'}" />
                </group>
            </search>
        </field>
    </record>

