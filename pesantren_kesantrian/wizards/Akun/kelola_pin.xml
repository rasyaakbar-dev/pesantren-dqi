<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Kelola PIN Form View -->
        <record id="wizard_kelola_pin_form" model="ir.ui.view">
            <field name="name">wizard.kelola.pin.form</field>
            <field name="model">wizard.kelola.pin</field>
            <field name="arch" type="xml">
                <form string="Kelola PIN Dompet Santri">
                    <group string="Cari Santri">
                        <group>
                            <field name="kartu_santri" string="No. Kartu" placeholder="Scan atau ketik nomor kartu..."/>
                            <field name="santri_id" string="Santri" 
                                   options="{'no_create_edit':True, 'no_create':True, 'no_open':True}"/>
                        </group>
                        <group>
                            <field name="nis"/>
                            <field name="kelas_id"/>
                        </group>
                    </group>
                    
                    <group string="Informasi Dompet" invisible="not santri_id">
                        <group>
                            <field name="kamar_id"/>
                        </group>
                        <group>
                            <label for="current_pin"/>
                            <div class="d-flex align-items-center">
                                <field name="current_pin" class="me-2" nolabel="1"/>
                                <field name="show_pin" invisible="1"/>
                                <button name="action_toggle_pin" type="object" 
                                        class="btn btn-link p-0" title="Tampilkan/Sembunyikan PIN">
                                    <i class="fa fa-eye" invisible="show_pin"/>
                                    <i class="fa fa-eye-slash" invisible="not show_pin"/>
                                </button>
                            </div>
                        </group>
                    </group>
                    
                    <group string="Ubah PIN" invisible="not santri_id">
                        <group>
                            <field name="new_pin" password="True" placeholder="Masukkan PIN baru (min. 4 digit)"/>
                        </group>
                        <group>
                            <field name="confirm_pin" password="True" placeholder="Ulangi PIN baru"/>
                        </group>
                    </group>
                    
                    <footer>
                        <button name="action_submit" string="Simpan PIN Baru" type="object" 
                                class="btn-primary" invisible="not santri_id"/>
                        <button string="Tutup" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
        
        <!-- Action Window -->
        <record id="action_wizard_kelola_pin" model="ir.actions.act_window">
            <field name="name">Kelola PIN Dompet</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">wizard.kelola.pin</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="pesantren_kesantrian.wizard_kelola_pin_form"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
