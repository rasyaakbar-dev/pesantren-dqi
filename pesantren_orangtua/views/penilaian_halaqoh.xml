<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- cdn.tahsin_quran action window -->
       <record id="cdn_penilaian_quran_action" model="ir.actions.act_window">
            <field name="name">Penilaian Halaqoh</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cdn.penilaian_quran</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="pesantren_kesantrian.view_penilaian_quran_tree" />
            <field name="domain">[]</field>
        </record>
        <record id="action_tree_view_cdn_penilaian_quran" model="ir.actions.act_window.view">
            <field name="sequence" eval="2" />
            <field name="view_mode">list</field>
            <field name="view_id" ref="pesantren_kesantrian.view_penilaian_quran_tree" />
            <field name="act_window_id" ref="cdn_penilaian_quran_action" />
        </record>
        <record id="action_form_view_cdn_penilaian_quran" model="ir.actions.act_window.view">
            <field name="sequence" eval="3" />
            <field name="view_mode">form</field>
            <field name="view_id" ref="pesantren_kesantrian.view_penilaian_quran_form" />
            <field name="act_window_id" ref="cdn_penilaian_quran_action" />
        </record>
        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="cdn_penilaian_quran_menu_act" name="Penilaian Halaqoh" parent="halaqoh_menu_categ" action="cdn_penilaian_quran_action" sequence="10"/>
    </data>
</odoo>