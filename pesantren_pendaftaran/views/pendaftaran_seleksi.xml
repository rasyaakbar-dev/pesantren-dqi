<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- View untuk SoalSeleksi -->
        <record id="view_soal_seleksi_tree" model="ir.ui.view">
            <field name="name">seleksi.soal.tree</field>
            <field name="model">seleksi.soal</field>
            <field name="arch" type="xml">
                <list string="Soal Seleksi">
                    <field name="name"/>
                    <field name="jenjang"/>
                    <field name="deskripsi"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_soal_seleksi_form" model="ir.ui.view">
            <field name="name">seleksi.soal.form</field>
            <field name="model">seleksi.soal</field>
            <field name="arch" type="xml">
                <form string="Soal Seleksi">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="jenjang"/>
                                <field name="nilai"/>
                            </group>
                            <group>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="deskripsi"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_soal_seleksi_search" model="ir.ui.view">
            <field name="name">seleksi.soal.search</field>
            <field name="model">seleksi.soal</field>
            <field name="arch" type="xml">
                <search string="Cari Soal Seleksi">
                    <field name="name"/>
                    <field name="deskripsi"/>
                    <field name="jenjang"/>
                    <filter string="Aktif" name="active" domain="[('active','=',True)]"/>
                    <filter string="Tidak Aktif" name="inactive" domain="[('active','=',False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Jenjang" name="group_jenjang" context="{'group_by':'jenjang'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action untuk Soal Seleksi -->
        <record id="action_soal_seleksi" model="ir.actions.act_window">
            <field name="name">Soal Seleksi</field>
            <field name="res_model">seleksi.soal</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>

        <!-- View untuk Penilaian Seleksi -->
        <record id="view_penilaian_seleksi_tree" model="ir.ui.view">
            <field name="name">seleksi.penilaian.tree</field>
            <field name="model">seleksi.penilaian</field>
            <field name="arch" type="xml">
                <list string="Penilaian Seleksi">
                    <field name="name"/>
                    <field name="nilai"/>
                    <field name="daftar_soal"/>
                </list>
            </field>
        </record>

        <record id="view_penilaian_seleksi_form" model="ir.ui.view">
            <field name="name">seleksi.penilaian.form</field>
            <field name="model">seleksi.penilaian</field>
            <field name="arch" type="xml">
                <form string="Penilaian Seleksi">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="nilai"/>
                            </group>
                            <group>
                                <field name="daftar_soal" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Soal Seleksi">
                                <field name="soal_ids" colspan="4">
                                    <list editable="bottom">
                                        <field name="soal_id" options="{'no_create': False, 'no_open': False}" domain="[('active','=',True)]"/>
                                        <field name="soal_name"/>
                                        <field name="deskripsi"/>
                                        <field name="jenjang"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_penilaian_seleksi_search" model="ir.ui.view">
            <field name="name">seleksi.penilaian.search</field>
            <field name="model">seleksi.penilaian</field>
            <field name="arch" type="xml">
                <search string="Cari Penilaian Seleksi">
                    <field name="name"/>
                    <field name="nilai"/>
                </search>
            </field>
        </record>

        <!-- Action untuk Penilaian Seleksi -->
        <record id="action_penilaian_seleksi" model="ir.actions.act_window">
            <field name="name">Penilaian Seleksi</field>
            <field name="res_model">seleksi.penilaian</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>