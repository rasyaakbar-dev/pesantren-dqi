<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!-- Sequence for Smart Billing Transaction -->
        <record id="seq_smart_billing_transaction" model="ir.sequence">
            <field name="name">Smart Billing Transaction</field>
            <field name="code">smart.billing.transaction</field>
            <field name="prefix">SB-%(year)s%(month)s-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
