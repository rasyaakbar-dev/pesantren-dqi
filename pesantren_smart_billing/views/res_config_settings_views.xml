<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!-- Smart Billing Settings in Account Settings -->
        <record id="res_config_settings_view_form_smart_billing" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.smart.billing</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='account']" position="inside">
                    <block title="Smart Billing" name="smart_billing_settings">
                        <setting id="smart_billing_provider_setting" string="Provider" help="Pilih provider untuk Smart Billing">
                            <field name="smart_billing_provider" widget="radio"/>
                        </setting>
                        
                        <setting id="smart_billing_mode_setting" string="Mode" help="Aktifkan Production Mode untuk menggunakan API live">
                            <field name="smart_billing_is_production"/>
                        </setting>
                        
                        <!-- BSI Specific Settings -->
                        <setting id="smart_billing_bsi_setting" string="BSI Configuration" help="Credentials untuk BSI Smart Billing" invisible="smart_billing_provider != 'bsi'">
                            <div class="alert alert-info mb-3">
                                <strong>BSI Smart Billing (BPI)</strong><br/>
                                Sandbox: Register di <a href="https://sandbox.bpi.co.id" target="_blank">sandbox.bpi.co.id</a><br/>
                                Production: Register di <a href="https://bsi.bpi.co.id" target="_blank">bsi.bpi.co.id</a>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_client_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_client_id" class="col-9 col-lg-6" placeholder="e.g. SBI0001"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_client_secret" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_client_secret" class="col-9 col-lg-6" password="True"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_partner_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_partner_id" class="col-9 col-lg-6" placeholder="Biasanya sama dengan Client ID"/>
                            </div>
                        </setting>
                        
                        <!-- BSI Mockup Testing Settings -->
                        <setting id="smart_billing_bsi_mockup_setting" string="Mockup Testing" help="Aktifkan untuk testing dengan mockup API lokal" invisible="smart_billing_provider != 'bsi'">
                            <div class="alert alert-warning mb-3">
                                <strong>⚠️ Mockup Mode</strong><br/>
                                Aktifkan ini untuk testing dengan API mockup FastAPI.
                            </div>
                            <div class="row mt-2">
                                <div class="col-12">
                                    <field name="smart_billing_bsi_use_mockup"/>
                                    <label for="smart_billing_bsi_use_mockup"/>
                                </div>
                            </div>
                            <div class="row mt-2" invisible="not smart_billing_bsi_use_mockup">
                                <label for="smart_billing_bsi_mockup_url" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_mockup_url" class="col-9 col-lg-6" placeholder="http://localhost:8001"/>
                            </div>
                        </setting>
                        
                        <!-- BSI Endpoints (untuk didaftarkan di BSI dashboard) -->
                        <setting id="smart_billing_bsi_endpoints_setting" string="BSI Endpoints" help="URL endpoint untuk didaftarkan di BSI Dashboard" invisible="smart_billing_provider != 'bsi'">
                            <div class="alert alert-warning mb-3">
                                <strong>Daftarkan URL ini di BSI Dashboard:</strong>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_auth_url" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_auth_url" class="col-9 col-lg-9" readonly="1" widget="CopyClipboardChar"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_inquiry_url" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_inquiry_url" class="col-9 col-lg-9" readonly="1" widget="CopyClipboardChar"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_bsi_payment_url" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_bsi_payment_url" class="col-9 col-lg-9" readonly="1" widget="CopyClipboardChar"/>
                            </div>
                        </setting>
                        
                        <!-- Generic Credentials (for dummy/tki) -->
                        <setting id="smart_billing_credentials_setting" string="Credentials" help="API credentials dari provider" invisible="smart_billing_provider == 'bsi'">
                            <div class="row mt-2">
                                <label for="smart_billing_server_key" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_server_key" class="col-9 col-lg-6"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_client_key" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_client_key" class="col-9 col-lg-6"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_merchant_id" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_merchant_id" class="col-9 col-lg-6"/>
                            </div>
                        </setting>
                        
                        <setting id="smart_billing_va_setting" string="Virtual Account" help="Konfigurasi Virtual Account">
                            <div class="row mt-2">
                                <label for="smart_billing_va_bank" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_va_bank" class="col-9 col-lg-4"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_expiry_hours" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_expiry_hours" class="col-9 col-lg-2"/>
                            </div>
                            <div class="row mt-2">
                                <label for="smart_billing_permanent_va_expiry_days" class="col-3 col-lg-3 o_light_label"/>
                                <field name="smart_billing_permanent_va_expiry_days" class="col-9 col-lg-2"/>
                            </div>
                        </setting>
                        
                        <setting id="smart_billing_webhook_setting" string="Generic Webhook URL" help="URL webhook generik" invisible="smart_billing_provider == 'bsi'">
                            <div class="row mt-2">
                                <field name="smart_billing_webhook_url" class="col-12" readonly="1" widget="CopyClipboardChar"/>
                            </div>
                        </setting>
                        
                        <setting id="smart_billing_features_setting" string="Features" help="Fitur otomatis">
                            <field name="smart_billing_auto_reconcile"/>
                            <field name="smart_billing_auto_topup_saldo"/>
                            <field name="smart_billing_send_notification"/>
                        </setting>
                        
                        <setting id="smart_billing_test_setting" string="Test Connection">
                            <button name="action_test_connection" type="object" string="Test Connection" class="btn-secondary"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
