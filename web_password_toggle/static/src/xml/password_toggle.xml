<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_password_toggle.PasswordToggleField" owl="1">
        <div class="d-flex align-items-center gap-1">
            <input t-ref="input" class="o_input flex-grow-1" t-att-type="fieldType" t-att-id="props.id" t-att-placeholder="props.placeholder" t-att-readonly="props.readonly" t-att-required="props.required" t-att-value="props.record.data[props.name]" t-on-input="(ev) => props.record.update({[props.name]: ev.target.value})" />
            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click.prevent.stop="togglePasswordVisibility" t-att-disabled="props.readonly" tabindex="-1">
                <i t-attf-class="fa fa-{{ passwordState.showPassword ? 'eye-slash' : 'eye' }}"/>
            </button>
        </div>
    </t>
</templates>